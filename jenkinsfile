pipeline {
    agent any

    tools {
        nodejs "node18"
    }

    stages {
        stage('Clone Repository') {
            steps {
                git 'https://github.com/PrasoonaOne/myproj-react-appln.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build Vite App') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t vite-react-app .'
            }
        }

        stage('Remove Old Container') {
            steps {
                bat 'docker rm -f vite-react-container'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run -d -p 3000:3000 --name vite-react-container vite-react-app'
            }
        }
    }
}